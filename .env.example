# Configuración de Pegasus Desktop
# Copia este archivo a .env y agrega tus valores reales.

# API de Resend para envíos de correo
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=alerts@tu-dominio.com

# Emails de alerta de seguridad
OWNER_ALERT_EMAIL=owner@tu-dominio.com
ALERT_EMAIL=alerts@tu-dominio.com

# Opcional: configuraciones SMTP de respaldo si no usas Resend
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-password-de-aplicacion
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
